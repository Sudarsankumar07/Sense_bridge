# Hugging Face API Key (for object detection)
HUGGING_FACE_API_KEY=your_huggingface_api_key_here

# Roboflow API Key (for object + currency detection)
ROBOFLOW_API_KEY=your_roboflow_api_key_here
ROBOFLOW_OBJECT_MODEL=obstacle-detection-yp5nu/4
ROBOFLOW_CURRENCY_MODEL=indian-currency

# Sign Language API Key (if using custom service)
SIGN_LANGUAGE_API_KEY=your_sign_language_api_key_here

# Cloud Provider Selection: 'roboflow' or 'google'
CLOUD_PROVIDER=roboflow

# Google Cloud Vision API Key (required when CLOUD_PROVIDER=google)
GOOGLE_CLOUD_VISION_API_KEY=your_google_cloud_vision_api_key_here

# OpenRouteService API Key (free, for walking navigation)
