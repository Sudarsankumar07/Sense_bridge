{
  "cli": {
    "version": ">= 12.6.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "CLOUD_PROVIDER": "google",
        "ROBOFLOW_CURRENCY_MODEL": "indian-currency"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "CLOUD_PROVIDER": "google",
        "ROBOFLOW_CURRENCY_MODEL": "indian-currency"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "CLOUD_PROVIDER": "google",
        "ROBOFLOW_CURRENCY_MODEL": "indian-currency"
      }
    }
  }
}